{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Code",
  "version": "0.1.0",
  "identifier": "dev.open-code.logic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Code",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
